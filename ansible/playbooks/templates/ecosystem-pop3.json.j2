{
  "apps": [
    {
      "name": "pop3-995",
      "script": "pop3.js",
      "exec_mode": "cluster",
      "wait_ready": true,
      "instances": "max",
      "pmx": false,
      "kill_timeout": 30000,
      "env_production": {
        "NODE_ENV": "production",
        "POP3_PORT": 995
      }
    },
    {
      "name": "pop3-2995",
      "script": "pop3.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "kill_timeout": 30000,
      "env_production": {
        "NODE_ENV": "production",
        "POP3_PORT": 2995
      }
    },
    {
      "name": "pop3-2110",
      "script": "pop3.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "kill_timeout": 30000,
      "node_args": "--tls-min-v1.0 --tls-cipher-list=DEFAULT@SECLEVEL=0",
      "env_production": {
        "NODE_ENV": "production",
        "POP3_PORT": 2110,
        "POP3_TLS_MIN_VERSION": "TLSv1"
      }
    }
  ],
  "deploy": {
    "production": {
      "user": "deploy",
      "host": [{% for host in groups['pop3'] %}"{{ hostvars[host].ansible_host }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "ref": "origin/master",
      "repo": "{{ lookup('env', 'GITHUB_REPO') }}",
      "path": "/var/www/production",
      "pre-deploy": "git reset --hard",
      "post-deploy": "bash ./scripts/pm2-post-deploy.sh ecosystem-pop3.json production"
    }
  }
}
